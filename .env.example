# ============================================
# CLAW Agent System — Configuración
# Copia este archivo como .env y completa
# los valores con tus credenciales reales
# ============================================

# --------------------------------------------
# AMBIENTE (local | server)
# local  = tu PC personal
# server = servidor cloud / Windows Server
# --------------------------------------------
CLAW_ENV=local

# --------------------------------------------
# LLM APIs
# --------------------------------------------
# Groq (cerebro principal — gratis)
# Obtener en: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# Google Gemini (LLM secundario — gratis)
# Obtener en: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Hyperspace local (completamente gratis, sin límites)
# Instalar en: https://agents.hyper.space
HYPERSPACE_BASE_URL=http://localhost:8080/v1
HYPERSPACE_ENABLED=false

# --------------------------------------------
# SUPABASE (memoria persistente entre sesiones)
# Obtener en: https://supabase.com → Settings → API
# --------------------------------------------
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# --------------------------------------------
# GITHUB (modificar repositorios)
# Obtener en: GitHub → Settings → Developer settings
# → Personal access tokens → Tokens (classic)
# Permisos requeridos: repo (full control)
# --------------------------------------------
GITHUB_TOKEN=your_github_token_here
GITHUB_USERNAME=ariaslopez
# Branches protegidas — NUNCA se hace push directo
GITHUB_PROTECTED_BRANCHES=main,master,production
# true = abre PR automático | false = push directo a branch nueva
GITHUB_AUTO_PR=true

# --------------------------------------------
# RUTAS DEL SISTEMA
# OUTPUT_PATH se configura en el setup interactivo
# Puedes sobreescribir manualmente aquí
# --------------------------------------------
OUTPUT_PATH=./output
LOGS_PATH=./logs

# --------------------------------------------
# UI WEB DASHBOARD
# --------------------------------------------
UI_HOST=127.0.0.1
UI_PORT=8000
# true = abre el browser automáticamente al iniciar
UI_AUTO_OPEN=true

# --------------------------------------------
# SEGURIDAD
# --------------------------------------------
# Dominios permitidos para conexiones de red
ALLOWED_DOMAINS=api.groq.com,generativelanguage.googleapis.com,api.github.com,supabase.co,api.coingecko.com,defillama.com,duckduckgo.com,pypi.org,npmjs.com
# Máximo de reintentos por agente antes de escalar
MAX_AGENT_RETRIES=3
# true = muestra diff antes de push a GitHub
GITHUB_CONFIRM_BEFORE_PUSH=false

# --------------------------------------------
# LOGGING
# --------------------------------------------
LOG_LEVEL=INFO
# true = guarda logs detallados de cada agente
AGENT_VERBOSE_LOGS=false
