# ============================================================
# CLAW Agent System v2.1 — Configuración
# Copia este archivo como .env y completa tus valores
# ============================================================

# ------------------------------------------------------------
# AMBIENTE
# local  = PC personal (Athlon 3000G / CPU-only)
# server = servidor cloud / Windows Server
# ------------------------------------------------------------
CLAW_ENV=local

# ============================================================
# ESTRATEGIA DE LLM
# ------------------------------------------------------------
# local_first  (default) → Ollama → Groq → Gemini → Hyperspace
# cloud_only             → Solo APIs externas
# local_only             → Solo Ollama, sin fallback cloud
# groq_only              → Solo Groq
# gemini_only            → Solo Gemini
# ============================================================
API_STRATEGY=local_first

# ============================================================
# OLLAMA — LLM LOCAL (provider primario)
# Instalar: https://ollama.com
# Pull modelo: ollama pull qwen2.5-coder:7b-q4_K_M
# ============================================================
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Perfil de hardware (auto-selecciona modelo y capas GPU) ---
# cpu_8gb   → llama3.2:3b-q4_K_M          (8 GB  RAM, sin GPU)
# cpu_16gb  → qwen2.5-coder:7b-q4_K_M     (16 GB RAM, sin GPU)
# cpu_24gb  → qwen2.5-coder:7b-q4_K_M     (24 GB RAM + iGPU offload) ← TU CONFIG ACTUAL
# gpu_8gb   → deepseek-coder-v2:16b-q4_K_M (GPU 8 GB VRAM)
# gpu_12gb  → qwen2.5-coder:14b-q4_K_M    (GPU 12 GB VRAM)
# gpu_16gb  → qwen2.5-coder:14b-q4_K_M    (GPU 16 GB VRAM)
# gpu_24gb  → qwen2.5-coder:32b-q4_K_M    (GPU 24 GB VRAM)
OLLAMA_HW_PROFILE=cpu_24gb

# Sobreescritura manual del modelo (opcional — deja vacío para usar perfil)
OLLAMA_MODEL=

# --- Capas offloaded a GPU/iGPU ---
# 0 = solo CPU
# 4 = offload parcial a iGPU Vega 3 (Athlon 3000G) — +10-20% velocidad
# 33+ = GPU dedicada RTX 3070 (8 GB VRAM)
# 43+ = GPU dedicada RTX 3080/4070 (12-16 GB VRAM)
# 65+ = GPU dedicada RTX 4090 / A100 (24+ GB VRAM)
LOCAL_GPU_LAYERS=4

# Tamaño de contexto en tokens
# 32768  = estándar para CPU (balance RAM/velocidad)
# 65536  = GPU 8-12 GB VRAM
# 128000 = GPU 24+ GB VRAM
LOCAL_CONTEXT_SIZE=32768

# Número de threads CPU para Ollama (= núcleos físicos de tu CPU)
# Athlon 3000G = 2 núcleos físicos / 4 threads
# Ajusta a tus núcleos: i5 gen12 = 6-12, Ryzen 5 = 6, etc.
OLLAMA_NUM_THREADS=4

# ============================================================
# GROQ — Fallback cloud gratuito #1 (14,400 tok/min gratis)
# Obtener en: https://console.groq.com
# ============================================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# ============================================================
# GOOGLE GEMINI — Fallback cloud gratuito #2 (1M tok/día)
# Obtener en: https://aistudio.google.com
# ============================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ============================================================
# HYPERSPACE — Fallback legacy local
# Instalar en: https://agents.hyper.space
# ============================================================
HYPERSPACE_BASE_URL=http://localhost:8080/v1
HYPERSPACE_ENABLED=false

# ============================================================
# MEMORIA EPISÓDICA (aprendizaje por experiencia)
# Requiere: pip install sentence-transformers chromadb
# ============================================================
EPISODIC_MEMORY_ENABLED=false
EPISODIC_MEMORY_BACKEND=sqlite          # sqlite | chromadb | supabase
EPISODIC_MEMORY_MIN_SUCCESS_SCORE=0.7   # solo guardar experiencias buenas
EPISODIC_MEMORY_TOP_K=3                 # cuántas memorias inyectar por tarea
# Modelo de embeddings local (sin API, ~80MB RAM)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================================
# SUPABASE — Memoria persistente entre sesiones (opcional)
# Obtener en: https://supabase.com → Settings → API
# ============================================================
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ============================================================
# GITHUB
# Obtener en: GitHub → Settings → Developer settings → PAT
# Permisos: repo (full control)
# ============================================================
GITHUB_TOKEN=your_github_token_here
GITHUB_USERNAME=your_github_username
GITHUB_PROTECTED_BRANCHES=main,master,production
GITHUB_AUTO_PR=true
GITHUB_CONFIRM_BEFORE_PUSH=true

# ============================================================
# RUTAS DEL SISTEMA
# ============================================================
OUTPUT_PATH=./output
LOGS_PATH=./logs

# ============================================================
# UI WEB DASHBOARD
# ============================================================
UI_HOST=127.0.0.1
UI_PORT=8000
UI_AUTO_OPEN=true

# ============================================================
# SEGURIDAD
# ============================================================
ALLOWED_DOMAINS=api.groq.com,generativelanguage.googleapis.com,api.github.com,supabase.co,api.coingecko.com,defillama.com,duckduckgo.com,pypi.org,npmjs.com,localhost
MAX_AGENT_RETRIES=3
LOG_LEVEL=INFO
AGENT_VERBOSE_LOGS=false
